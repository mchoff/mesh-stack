
# =============================================================================
#  meshcore-mqtt-proxy  --  proxy.env
#  Run with:  python3 meshcore-mqtt-proxy.py --env proxy.env
# =============================================================================

# -----------------------------------------------------------------------------
# DESTINATION ON/OFF SWITCHES
# Flip these without touching the config blocks below.
# Omitting DEST#_ENABLED is the same as yes.
# -----------------------------------------------------------------------------
DEST1_ENABLED=yes
DEST2_ENABLED=yes
DEST3_ENABLED=yes
DEST4_ENABLED=yes
DEST5_ENABLED=yes
DEST6_ENABLED=yes
DEST7_ENABLED=yes

# -----------------------------------------------------------------------------
# LISTEN  —  the broker your device/radio connects to
# -----------------------------------------------------------------------------
LISTEN_PORT=1888
LISTEN_USER=                 # leave blank to allow anonymous connections
LISTEN_PASS=

# -----------------------------------------------------------------------------
# KEYS  —  required when any destination uses AUTH=token
# -----------------------------------------------------------------------------

PUBLIC_KEY=pub.key
PRIVATE_KEY=priv.key
# PRIVATE_KEY_FILE=/home/user/.meshcore/private.key   # alternative: read key from file

TOKEN_TTL=3600               # seconds before a JWT expires (auto-refreshed 5 min early)

# Optional: embed ownership info in the JWT payload
# OWNER_PUBLIC_KEY=	# optional
OWNER_EMAIL=      #your email, links ownership to your email (for analyzers with website login)

# -----------------------------------------------------------------------------
# FORWARDING
# -----------------------------------------------------------------------------
QOS=0                        # global default: 0 = fire-and-forget  |  1 = wait for broker ack
                             # override per destination with DEST#_QOS=1
MAX_PAYLOAD=65536            # bytes; messages larger than this are dropped with a warning

# =============================================================================
# DESTINATIONS
# AUTH modes:  none | userpass | token
# =============================================================================

# -----------------------------------------------------------------------------
# DESTINATION 1  —  local broker (no login)
# -----------------------------------------------------------------------------
DEST1_NAME=local
DEST1_HOST=127.0.0.1
DEST1_PORT=1883
DEST1_TLS=no
DEST1_WEBSOCKET=no
DEST1_AUTH=none
# DEST1_USER=               # only used when AUTH=userpass
# DEST1_PASS=               # only used when AUTH=userpass
# DEST1_AUD=                # only used when AUTH=token
# DEST1_REWRITE_IATA=MCO:ORL
# DEST1_REWRITE_KEEP=no
# DEST1_RETAIN_STATUS=no
# DEST1_RETAIN=no
# DEST1_QOS=0               # overrides global QOS for this destination only

# -----------------------------------------------------------------------------
# DESTINATION 2  —  LetsMesh US
# -----------------------------------------------------------------------------
DEST2_NAME=letsmesh_us
DEST2_HOST=mqtt-us-v1.letsmesh.net
DEST2_PORT=443
DEST2_TLS=yes
DEST2_WEBSOCKET=yes
DEST2_AUTH=token
# DEST2_USER=               # only used when AUTH=userpass
# DEST2_PASS=               # only used when AUTH=userpass
DEST2_AUD=mqtt-us-v1.letsmesh.net
# DEST2_REWRITE_IATA=MCO:ORL
# DEST2_REWRITE_KEEP=no
# DEST2_RETAIN_STATUS=no
# DEST2_RETAIN=no
# DEST2_QOS=0               # overrides global QOS for this destination only

# -----------------------------------------------------------------------------
# DESTINATION 3  —  LetsMesh EU
# -----------------------------------------------------------------------------
DEST3_NAME=letsmesh_eu
DEST3_HOST=mqtt-eu-v1.letsmesh.net
DEST3_PORT=443
DEST3_TLS=yes
DEST3_WEBSOCKET=yes
DEST3_AUTH=token
# DEST3_USER=               # only used when AUTH=userpass
# DEST3_PASS=               # only used when AUTH=userpass
DEST3_AUD=mqtt-eu-v1.letsmesh.net
# DEST3_REWRITE_IATA=MCO:ORL
# DEST3_REWRITE_KEEP=no
# DEST3_RETAIN_STATUS=no
# DEST3_RETAIN=no
# DEST3_QOS=0               # overrides global QOS for this destination only

# -----------------------------------------------------------------------------
# DESTINATION 4  —  MeshMapper
# Uncomment REWRITE lines if your region wants ORL; KEEP=yes sends both MCO and ORL
# -----------------------------------------------------------------------------
DEST4_NAME=meshmapper
DEST4_HOST=mqtt.meshmapper.net
DEST4_PORT=443
DEST4_TLS=yes
DEST4_WEBSOCKET=yes
DEST4_AUTH=token
# DEST4_USER=               # only used when AUTH=userpass
# DEST4_PASS=               # only used when AUTH=userpass
DEST4_AUD=mqtt.meshmapper.net
# DEST4_REWRITE_IATA=MCO:ORL
# DEST4_REWRITE_KEEP=no     # yes = send to BOTH original and rewritten topic
# DEST4_RETAIN_STATUS=no
# DEST4_RETAIN=no
# DEST4_QOS=0               # overrides global QOS for this destination only

# -----------------------------------------------------------------------------
# DESTINATION 5  —  mc.flmesh.us / JNT Connections
# -----------------------------------------------------------------------------
DEST5_NAME=jnt
DEST5_HOST=mcmqtt.jntconnections.com
DEST5_PORT=443
DEST5_TLS=yes
DEST5_WEBSOCKET=yes
DEST5_AUTH=token
# DEST5_USER=               # only used when AUTH=userpass
# DEST5_PASS=               # only used when AUTH=userpass
DEST5_AUD=mcmqtt.jntconnections.com
# DEST5_REWRITE_IATA=MCO:ORL
# DEST5_REWRITE_KEEP=no
# DEST5_RETAIN_STATUS=no
# DEST5_RETAIN=no
# DEST5_QOS=0               # overrides global QOS for this destination only

# -----------------------------------------------------------------------------
# DESTINATION 6  —  EastMesh.sh / meshtrace
# RETAIN=yes — all forwarded messages are marked retained on this broker
# -----------------------------------------------------------------------------
DEST6_NAME=ecmeshcore
DEST6_HOST=mqtt.eastme.sh
DEST6_PORT=443
DEST6_TLS=yes
DEST6_WEBSOCKET=yes
DEST6_AUTH=token
# DEST6_USER=               # only used when AUTH=userpass
# DEST6_PASS=               # only used when AUTH=userpass
DEST6_AUD=mqtt.eastme.sh
# DEST6_REWRITE_IATA=MCO:ORL
# DEST6_REWRITE_KEEP=no
# DEST6_RETAIN_STATUS=no
DEST6_RETAIN=yes
# DEST6_QOS=0               # overrides global QOS for this destination only


# -----------------------------------------------------------------------------
# DESTINATION 7 -  WAEV.app map
# -----------------------------------------------------------------------------
DEST7_NAME=waev
DEST7_HOST=mqtt.waev.app
DEST7_PORT=443
DEST7_TLS=yes
DEST7_WEBSOCKET=yes
DEST7_AUTH=token
# DEST5_USER=               # only used when AUTH=userpass
# DEST5_PASS=               # only used when AUTH=userpass
DEST7_AUD=mqtt.waev.app
# DEST7_REWRITE_IATA=MCO:ORL
# DEST7_REWRITE_KEEP=no
# DEST7_RETAIN_STATUS=no
# DEST7_RETAIN=no
# DEST7_QOS=0
